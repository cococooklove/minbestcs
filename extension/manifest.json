{
  "manifest_version": 3,
  "name": "민베스트 리뷰 수집",
  "version": "1.1",
  "description": "네이버 스마트스토어 리뷰를 한 번에 수집합니다.",
  "permissions": ["cookies", "storage", "tabs", "downloads", "scripting"],
  "host_permissions": ["https://*.naver.com/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "민베스트 리뷰 수집"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://sell.smartstore.naver.com/*"],
      "js": ["content_main.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://sell.smartstore.naver.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
